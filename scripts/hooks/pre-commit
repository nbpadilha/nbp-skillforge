#!/bin/sh
# nbp-skillforge pre-commit (VERSIONED source of truth). The .git/hooks/pre-commit is a thin
# shim that delegates here — so this logic is reviewed in git and never drifts. Two gates:
#   1) secret scan over staged additions (blocks .env files + token-shaped strings)
#   2) drift-gate (forge check), when this repo is a forge project
# Bypass with `git commit --no-verify` only if you are certain (discouraged).

fail=0

# ── 1) secret scan ───────────────────────────────────────────────────────────
# Block committing env files. Read names one-per-line (IFS= read -r tolerates spaces);
# the `while` runs in a subshell, so we collect hits via its stdout, not a shared var.
# Match on the BASENAME so .env / .env.local / prod.env / secrets.env.bak are all caught,
# while templates (*.example / *.sample / *.template) are allowed.
env_hits=$(git diff --cached --name-only --diff-filter=ACM | while IFS= read -r f; do
  base=${f##*/}
  case "$base" in
    *.example|*.sample|*.template) ;;
    .env|.env.*|*.env|*.env.*) echo "$f" ;;
  esac
done)
if [ -n "$env_hits" ]; then
  echo "✗ refusing to commit env file(s):"; echo "$env_hits" | sed 's/^/    /'
  fail=1
fi

# Token-shaped strings in ADDED lines (skip the +++ file headers).
patterns='(gh[pousr]_[A-Za-z0-9]{30,})|(github_pat_[A-Za-z0-9_]{50,})|(sk-[A-Za-z0-9_-]{20,})|(npm_[A-Za-z0-9]{30,})|(AKIA[0-9A-Z]{16})|(-----BEGIN [A-Z ]*PRIVATE KEY-----)'
hits=$(git diff --cached --no-color -U0 | grep -E '^\+' | grep -Ev '^\+\+\+' | grep -En "$patterns" 2>/dev/null || true)
if [ -n "$hits" ]; then
  echo "✗ possible secret in staged changes:"
  echo "$hits" | head -10
  fail=1
fi

# ── 2) drift-gate ────────────────────────────────────────────────────────────
# Prefer a repo-defined `forge:check` script (lets a repo point check at a sub-root);
# else, if the repo root is itself a forge project, run the CLI — with two guarantees:
#
# LOCAL-ONLY resolution (Fable B3): `npx --no-install` is IGNORED by npm ≥9 — it hit the npm
# registry on every commit (network dependency + running remote @latest code at commit time,
# and E404-blocking every commit while the package is unpublished/offline). We only ever run a
# binary that is already present; when none is found the gate is skipped with a note.
#
# INDEX-exact gating (Fable B4): the check runs against a `git checkout-index` materialization
# of the STAGED tree, not the worktree — staging a recipe edit without its rebuilt output used
# to pass a drifted commit (worktree was clean; the commit was not).
if grep -q '"forge:check":' package.json 2>/dev/null; then
  # Repo-defined script: the repo owns its semantics (may target a sub-root); runs as defined —
  # against the WORKTREE (an npm script can't be redirected into the index materialization: it
  # may need node_modules, which the index doesn't carry). DOCUMENTED residual: with a custom
  # script, a partially-staged recipe/output pair is not caught here — the index-exact gate below
  # only applies to the default (forge.config.json at root) path.
  npm run -s forge:check || fail=1
elif [ -f forge.config.json ]; then
  forge_bin=""
  if [ -x "node_modules/.bin/nbp-skillforge" ]; then forge_bin="node_modules/.bin/nbp-skillforge"
  elif command -v nbp-skillforge >/dev/null 2>&1; then forge_bin="nbp-skillforge"
  fi
  if [ -n "$forge_bin" ]; then
    idx_ok=0
    idx_tmp=$(mktemp -d 2>/dev/null) || idx_tmp=""
    if [ -n "$idx_tmp" ]; then
      # checkout-index's exit code is CHECKED: a partial materialization (sparse checkout,
      # permissions, exotic paths) must never be silently checked as if it were the full index —
      # on any failure we fall back to the worktree check below.
      if git checkout-index -a -f --prefix="$idx_tmp/" && [ -f "$idx_tmp/forge.config.json" ]; then
        "$forge_bin" check --root "$idx_tmp" || fail=1
        idx_ok=1
      fi
      rm -rf "$idx_tmp"
    fi
    if [ "$idx_ok" -ne 1 ]; then
      "$forge_bin" check || fail=1   # index materialization unavailable → worktree check (better than nothing)
    fi
  else
    echo "· drift-gate skipped: nbp-skillforge CLI not found locally (npm i -D nbp-skillforge to enable it)"
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-commit blocked (nbp-skillforge)."
  exit 1
fi
